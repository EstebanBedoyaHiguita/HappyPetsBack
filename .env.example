# ============================================
# HAPPY PETS - CONFIGURACIÓN DE ENTORNO
# ============================================

# AMBIENTE
NODE_ENV=development  # development | production

# ============================================
# BASE DE DATOS - MongoDB
# ============================================
# Para desarrollo local:
MONGODB_URI=mongodb://localhost:27017/happypets

# Para producción con MongoDB Atlas:
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/happypets?retryWrites=true&w=majority

# ============================================
# AUTENTICACIÓN - JWT
# ============================================
# Generar un secret seguro para producción:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================
# CLOUDINARY - Almacenamiento de imágenes
# ============================================
# Crear cuenta gratuita en: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# BOLD - Pasarela de pagos (Colombia)
# ============================================
# Crear cuenta en: https://bold.co
BOLD_API_URL=https://api.bold.co
BOLD_API_KEY=your-bold-identity-key
BOLD_SECRET_KEY=your-bold-secret-key

# ============================================
# APLICACIÓN
# ============================================
PORT=3000

# URL del frontend (para CORS)
# Desarrollo:
FRONTEND_URL=http://localhost:5173

# Producción (Render):
# FRONTEND_URL=https://happypets-web.onrender.com
